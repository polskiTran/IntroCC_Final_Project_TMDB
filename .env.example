# Copy to .env. DO NOT COMMIT the real .env.
TMDB_API_KEY=your_tmdb_v3_api_key
TMDB_BEARER_TOKEN=your_tmdb_v4_bearer_token_optional

# Where Streamlit/ML read data: local (default) or s3. Ingest always writes locally;
# then run: uv run python -m src.ingest upload-s3
# DATA_BACKEND=local
# DATA_BACKEND=s3
# S3_BUCKET=your-bucket-name
# S3_PREFIX=
# AWS_REGION=us-east-1
# S3_UPLOAD_CONCURRENCY=24
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Ingestion (optional)
# SAVE_DISCOVER_PAGES=false
# DISCOVER_PAGE_CONCURRENCY=15
